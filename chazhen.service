[Unit]
Description=插针Bot v4
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/chazhen4/live
ExecStart=/usr/bin/python3 server.py --host 0.0.0.0 --port 8888
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=TZ=UTC

[Install]
WantedBy=multi-user.target
